# PetaLife ATM - AWS DynamoDB Configuration Example
# Copy this file to '.env' and fill in your actual AWS access parameters.

# AWS region where your DynamoDB resides
AWS_REGION=ap-east-1

# IAM User Credentials with DynamoDB read permissions (e.g. AmazonDynamoDBReadOnlyAccess policy)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Name of your user profiles table in DynamoDB
DYNAMODB_TABLE_NAME=PetaLifeUsers
