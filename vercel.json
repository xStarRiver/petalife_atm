{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/ws",
      "dest": "server.js"
    },
    {
      "src": "/$",
      "redirect": "/kiosk.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
